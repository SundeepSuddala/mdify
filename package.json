{
  "name": "mdify",
  "version": "1.0.0",
  "description": "MCP server that converts PDF, DOCX, XLSX and CSV files to markdown before Claude Code reads them — cuts token usage by up to 98%.",
  "type": "module",
  "main": "src/index.js",
  "bin": {
    "mdify-setup": "./setup.js"
  },
  "scripts": {
    "start": "node src/index.js",
    "setup": "node setup.js",
    "test": "node --test"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "mcp",
    "claude-code",
    "markdown",
    "token-optimization",
    "pdf",
    "docx"
  ],
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "mammoth": "^1.8.0",
    "pdf-parse": "^1.1.1",
    "xlsx": "^0.18.5"
  }
}
